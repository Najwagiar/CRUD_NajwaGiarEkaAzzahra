generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  description String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  events Event[]

  @@map("categories")
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  categoryId  Int      @map("category_id")
  location    String
  dateEvent   DateTime @map("date_event")
  description String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  pembicaraId  Int      @map("pembicara_id")

  category Category @relation(fields: [categoryId], references: [id])
  pembicara Pembicara @relation(fields: [pembicaraId], references: [id])

  @@map("events")
}

model Pembicara {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  image     String
  createdAt DateTime @default(now()) @map("created_at")

  events Event[]

  @@map("pembicaras")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  password  String
  email     String   @unique
  foto      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Roles {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("roles")
}